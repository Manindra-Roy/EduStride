PORT=5000
MONGO_URI=your_mongodb_uri_here
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_user_here
EMAIL_PASS=your_email_pass_here

# Brevo config (used for Nodemailer SMTP locally and Brevo HTTP API in production)
BREVO_USER=your_brevo_smtp_login_username_here
BREVO_PASS=your_brevo_api_key_or_smtp_password_here
BREVO_SENDER=your_verified_sender_email_here

# Cloudinary Config (Uncomment and fill to enable Cloud Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
