<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.github.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true"
    tools:context=".ui.ProfileActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Toolbar header navigation -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/profileToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/white"
            app:title="My Profile Settings"
            app:titleTextColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- User Profile Avatar Display -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLargeAvatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="60dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/primary_indigo"
            app:cardBackgroundColor="#1F1B3D"
            app:layout_constraintTop_toBottomOf="@id/profileToolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/imgLargeProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/primary_indigo" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aether Member"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardLargeAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtUserRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Account"
            android:textColor="@color/primary_indigo"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/txtUserName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- File Pick trigger -->
        <Button
            android:id="@+id/btnChooseAvatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload New Photo"
            android:layout_marginTop="16dp"
            android:backgroundTint="#242253"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/txtUserRole"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Repositioning Editor (Visible only when local photo loaded) -->
        <LinearLayout
            android:id="@+id/layoutCropper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#1B1C31"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnChooseAvatar">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crop &amp; Reposition Avatar"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Reposition viewport preview -->
            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@color/black"
                android:layout_marginBottom="16dp">

                <!-- Preview Crop circle -->
                <ImageView
                    android:id="@+id/imgCropPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="center"
                    android:src="@android:drawable/ic_menu_gallery" />

                <!-- Simple visual crop frame overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/crop_circle_mask" />

            </FrameLayout>

            <!-- Adjust Sliders -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scale / Zoom"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbZoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="0"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pan Horizontal (X)"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbPanX"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="100"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pan Vertical (Y)"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sbPanY"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="100"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnSaveAvatar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Repositioned Avatar"
                android:backgroundTint="@color/primary_indigo" />

        </LinearLayout>

        <!-- System Theme Customizer Panel -->
        <LinearLayout
            android:id="@+id/layoutThemePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layoutCropper">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Theme Accent"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Simple RadioGroup representing color themes -->
            <RadioGroup
                android:id="@+id/rgThemeSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1B1C31"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/rbThemeIndigo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Indigo Classy"
                    android:textColor="@color/white" />

                <RadioButton
                    android:id="@+id/rbThemeEmerald"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emerald Garden"
                    android:textColor="@color/white" />

                <RadioButton
                    android:id="@+id/rbThemeAmber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Warm Amber"
                    android:textColor="@color/white" />

                <RadioButton
                    android:id="@+id/rbThemeRose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crimson Rose"
                    android:textColor="@color/white" />

                <RadioButton
                    android:id="@+id/rbThemeSystemDefault"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inherit System Default"
                    android:textColor="@color/white" />

            </RadioGroup>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
