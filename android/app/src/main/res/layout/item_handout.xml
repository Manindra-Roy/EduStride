<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="#1B1C31"
    app:strokeColor="#2C2E4E"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/btnDownload"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/txtHandoutTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mathematics Final Mock Test"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtHandoutDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prepare with calculus modules"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtSubjectBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MATH"
                    android:textColor="@color/accent_gold"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="#2E2922"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txtClassLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Class VII"
                    android:textColor="#88FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txtPipelineStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distributed"
                    android:textColor="@color/primary_indigo"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDownload"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackground"
            android:src="@android:drawable/stat_sys_download"
            app:tint="@color/primary_indigo"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
