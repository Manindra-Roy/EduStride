<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:paddingVertical="4dp"
    android:paddingStart="8dp"
    android:paddingEnd="48dp">

    <TextView
        android:id="@+id/txtSenderName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jane Smith"
        android:textColor="@color/accent_gold"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="2dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#2C2E4E"
        app:strokeWidth="1dp"
        app:strokeColor="#3D406E">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/txtMessageContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Received message content"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:24"
                android:textColor="#88FFFFFF"
                android:textSize="9sp"
                android:layout_gravity="end"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
