<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="#1B1C31"
    app:strokeColor="#2C2E4E"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/layoutStatus"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/txtStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRollNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roll No: 12"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/txtAttendanceStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="92% Attendance (23/25)"
                android:textColor="@android:color/darker_gray"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatusIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                app:cardCornerRadius="4dp"
                app:cardBackgroundColor="@android:color/holo_green_dark"
                app:strokeWidth="0dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/txtLedgerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAID"
                android:textColor="@android:color/holo_green_light"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
